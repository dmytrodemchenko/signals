{
  "compilerOptions": {
    "target": "es2016",
    "module": "es2020",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "declaration": false,
    "sourceMap": false,
    "outDir": "dist"
  },
  "include": ["src", "runner.ts"],
  "exclude": ["src/**/*.test.ts"]
}
