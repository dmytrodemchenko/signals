{
  "name": "@demchenko.di/signals",
  "version": "3.0.0",
  "description": "Zero-dependency reactive signals for TypeScript and JavaScript.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./min": {
      "import": "./dist/index.min.js",
      "default": "./dist/index.min.js"
    }
  },
  "files": [
    "dist",
    "demo",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "scripts": {
    "build": "vite build && MINIFY=true vite build && node scripts/minify.js && tsc --emitDeclarationOnly",
    "build:debug": "vite build --minify false && tsc --emitDeclarationOnly",
    "check": "tsc --noEmit --pretty false",
    "prepack": "npm run build",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "signals",
    "reactivity",
    "state",
    "typescript",
    "nodejs",
    "node.js",
    "nestjs",
    "nest.js",
    "angular",
    "javascript",
    "RxJS",
    "reactive programming",
    "reactive state management",
    "reactive libraries",
    "reactive programming libraries",
    "reactive programming tools",
    "reactive programming frameworks"
  ],
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "@vitest/coverage-v8": "^4.1.5",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "^3.8.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.0",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=18"
  }
}
